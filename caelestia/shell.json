{
    "bar": {
        "status": {
            "showMicrophone": true
        },
        "tray": {
            "recolour": true
        }
    },
    "services": {
        "useFahrenheit": false
    },
    "session": {
        "commands": {
            "hibernate": [
                "systemctl",
                "sleep"
            ],
            "logout": [
                "bash",
                "-c",
                "pkill -KILL -u $(whoami)"
            ],
            "reboot": [
                "systemctl",
                "reboot"
            ],
            "shutdown": [
                "systemctl",
                "poweroff"
            ]
        },
        "dragThreshold": 30,
        "enabled": true,
        "vimKeybinds": false
    }
}
